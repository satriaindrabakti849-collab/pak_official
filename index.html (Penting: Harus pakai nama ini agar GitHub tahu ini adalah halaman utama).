<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ASCI | Astronomy Science Community</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            margin: 0;
            padding: 0;
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow-x: hidden;
            color: #fff;
        }

        /* Animasi Glow Background */
        .glow {
            position: fixed;
            top: 50%; left: 50%;
            width: 300px; height: 300px;
            background: rgba(0, 212, 255, 0.2);
            filter: blur(100px);
            border-radius: 50%;
            z-index: -1;
            transform: translate(-50%, -50%);
        }

        /* Container dengan Animasi Fade In */
        .glass-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 40px;
            border-radius: 20px;
            width: 100%;
            max-width: 450px;
            text-align: center;
            animation: fadeIn 1s ease-in-out;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h1 { font-family: 'Montserrat', sans-serif; font-size: 24px; margin-bottom: 5px; color: #00d4ff; }
        .subtitle { font-size: 12px; letter-spacing: 1px; color: #bdc3c7; margin-bottom: 30px; }

        input, select, textarea {
            width: 100%;
            padding: 12px;
            margin-bottom: 15px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 10px;
            color: #fff;
            outline: none;
        }

        input::placeholder { color: #ccc; }

        button {
            width: 100%;
            padding: 14px;
            background: #00d4ff;
            border: none;
            color: #000;
            font-weight: bold;
            border-radius: 10px;
            cursor: pointer;
            transition: 0.3s;
            text-transform: uppercase;
        }

        button:hover { background: #0097bb; transform: scale(1.02); }

        #introPage { display: none; max-width: 600px; }

        .info-box {
            background: rgba(0, 212, 255, 0.1);
            padding: 15px;
            border-radius: 10px;
            font-size: 12px;
            border-left: 4px solid #00d4ff;
            text-align: left;
            margin-top: 20px;
        }
    </style>
</head>
<body>

