    <div class="glass-card" id="loginBox">
        <h1>𝐀𝐒𝐂𝐈</h1>
        <div class="subtitle">Astronomy Science Community of Indonesia</div>
        
        <input type="text" id="user" placeholder="Username">
        <input type="password" id="pass" placeholder="Password (Bebas)">
        <button onclick="lanjut()">Akses Portal</button>
    </div>

    <div class="glass-card" id="introPage">
        <h1>Formulir Introduksi</h1>
        <p style="font-size: 13px; color: #bdc3c7;">Lengkapi data diri Anda untuk bergabung.</p>
        
        <input type="text" id="nama" placeholder="Nama Lengkap">
        
        <div style="display: flex; gap: 10px;">
            <input type="number" id="umur" placeholder="Umur" style="flex: 1;">
            <input type="date" id="tgl" style="flex: 2;">
        </div>

        <div style="display: flex; gap: 10px;">
            <select id="jk" style="flex: 1;">
                <option value="">Gender</option>
                <option value="Laki-laki">Laki-laki</option>
                <option value="Perempuan">Perempuan</option>
            </select>
            <input type="text" id="tk" placeholder="Akun TikTok" style="flex: 1;">
        </div>

        <input type="text" id="asal" placeholder="Asal Daerah">
        <textarea id="alasan" rows="3" placeholder="Alasan bergabung..."></textarea>

        <div class="info-box">
            🛡️ <b>Security & AI Active:</b> Data dienkripsi secara ketat. Sistem AI kami akan melakukan verifikasi otomatis pada profil Anda.
        </div>

        <button onclick="gabung()" style="margin-top: 20px;">Verifikasi & Join Grup</button>
    </div>

